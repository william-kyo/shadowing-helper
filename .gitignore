# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files and local databases
.env*
!/.env.example
prisma/*.db
prisma/*.db-journal

# local runtime storage
/storage/
/.hermes/

# supabase CLI (generated by `supabase link`)
/supabase/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
