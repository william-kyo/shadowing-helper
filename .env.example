# LOCAL DEV: use SQLite. For Vercel/production, set DATABASE_URL to Supabase Postgres.
DATABASE_URL="file:./dev.db"
STORAGE_ROOT="storage/projects"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"

# Groq Cloud API key for Whisper transcription (free tier: whisper-large-v3-turbo on_demand)
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=""

# Configure these locally on the Raspberry Pi when OCR / segmentation starts using the LLM.
GPT54_BASE_URL=""
GPT54_API_KEY=""
GPT54_MODEL="gpt-5.4"
