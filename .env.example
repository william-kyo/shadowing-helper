# LOCAL DEV: uses SQLite (DATABASE_URL below).
# For Vercel/production: set DATABASE_URL env var to:
# postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="file:./dev.db"
STORAGE_ROOT="storage/projects"
STORAGE_BUCKET="app-media"
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_xxx"
# Needed only for one-off migration scripts. The script signs in as a normal user
# and migrates only that user's files through your existing Storage RLS policies.
MIGRATION_USER_EMAIL=""
MIGRATION_USER_PASSWORD=""

# Groq Cloud API key for Whisper transcription (free tier: whisper-large-v3-turbo on_demand)
# Get yours at https://console.groq.com/keys
GROQ_API_KEY=""

# Configure these locally on the Raspberry Pi when OCR / segmentation starts using the LLM.
GPT54_BASE_URL=""
GPT54_API_KEY=""
GPT54_MODEL="gpt-5.4"
