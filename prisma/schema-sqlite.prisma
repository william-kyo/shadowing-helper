generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  draft
  segmenting
  processed
  ready
  failed
}

enum StageStatus {
  not_started
  in_progress
  completed
}

model Project {
  id                String         @id @default(cuid())
  userId            String?
  title             String
  audioPath         String
  audioOriginalName String
  audioMimeType     String
  audioDurationMs   Int?
  audioFileHash     String?
  audioPcmHash      String?
  status            ProjectStatus  @default(draft)
  rawExtractedText  String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  user              User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceImages      SourceImage[]
  segments          Segment[]

  @@index([userId, createdAt])
  @@index([audioFileHash])
  @@index([audioPcmHash])
}

model User {
  id                String             @id @default(cuid())
  supabaseUserId    String             @unique
  email             String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  // Set once, the first time the streak reaches HABIT_GOAL_DAYS. Keeps the
  // 21-day-challenge success permanent even after the activity evidence
  // (StageProgress.updatedAt rows) decays or falls out of the query window.
  habitAchievedAt   DateTime?
  projects          Project[]
  streakMakeups     StreakMakeup[]
  pushSubscriptions PushSubscription[]
}

// One Web Push subscription per browser/device. `endpoint` is globally unique
// (assigned by the browser's push service); `p256dh`/`auth` are the client
// keys web-push uses to encrypt payloads for this subscription.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// A streak "make-up" (補卡): the user repairs a missed past day by spending a
// segment they fully completed today. `dateKey` is the repaired day (JST,
// YYYY-MM-DD); `sourceSegmentId` is the full-segment completion that paid for
// it — unique per user so a single completion can fund only one make-up.
model StreakMakeup {
  id              String   @id @default(cuid())
  userId          String
  dateKey         String
  sourceSegmentId String
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, dateKey])
  @@unique([userId, sourceSegmentId])
  @@index([userId])
}

model SourceImage {
  id           String   @id @default(cuid())
  projectId    String
  imagePath    String
  originalName String
  mimeType     String
  sortOrder    Int
  ocrText      String?
  createdAt    DateTime @default(now())
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Segment {
  id              String          @id @default(cuid())
  projectId       String
  index           Int
  title           String?
  text            String
  audioPath       String
  startMs         Int?
  endMs           Int?
  notes           String?
  whisperSegments Json?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  progress        StageProgress[]
  recordings      Recording[]

  @@unique([projectId, index])
}

model StageProgress {
  id             String      @id @default(cuid())
  segmentId      String
  stage          Int
  status         StageStatus @default(not_started)
  dictationInput String?
  studyNotes     String?
  textVisible    Boolean?
  metadata       Json?
  completedAt    DateTime?
  updatedAt      DateTime    @updatedAt
  segment        Segment     @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@unique([segmentId, stage])
  @@index([segmentId])
}

model Recording {
  id            String   @id @default(cuid())
  segmentId     String
  stage         Int
  filePath      String
  durationMs    Int?
  sentenceIndex Int?
  createdAt     DateTime @default(now())
  segment       Segment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)

  @@index([segmentId])
}

// One row per accepted call to a rate-limited endpoint. A sliding-window
// limiter (src/lib/rate-limit.ts) counts rows for (userId, bucket) within the
// window. DB-backed so the limit holds across serverless instances.
model RateLimitHit {
  id        String   @id @default(cuid())
  userId    String
  bucket    String
  createdAt DateTime @default(now())

  @@index([userId, bucket, createdAt])
}
